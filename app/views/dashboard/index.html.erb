<% content_for :title, "Dashboard - Shortener" %>

<style>
  .dashboard { max-width: 960px; margin: 2rem auto; padding: 0 1rem; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: #1a1a1a; }
  .dashboard h1 { margin-bottom: 1.5rem; }
  .stats { display: flex; gap: 1rem; margin-bottom: 2rem; }
  .stat { flex: 1; background: #f5f5f7; border-radius: 8px; padding: 1rem 1.25rem; }
  .stat .value { font-size: 2rem; font-weight: 700; display: block; }
  .stat .label { font-size: 0.85rem; color: #666; text-transform: uppercase; letter-spacing: 0.03em; }
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 0.6rem 0.75rem; border-bottom: 1px solid #e5e5e7; font-size: 0.9rem; }
  th { color: #666; font-weight: 600; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.03em; }
  td.original-url { max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  td.clicks { text-align: right; font-variant-numeric: tabular-nums; }
  .empty { color: #666; padding: 2rem 0; text-align: center; }
  a { color: #0a66c2; }
</style>

<div class="dashboard">
  <h1>Shortener Dashboard</h1>

  <div class="stats">
    <div class="stat">
      <span class="value"><%= @total_links %></span>
      <span class="label">Links</span>
    </div>
    <div class="stat">
      <span class="value"><%= @total_clicks %></span>
      <span class="label">Total Clicks</span>
    </div>
  </div>

  <% if @links.any? %>
    <table>
      <thead>
        <tr>
          <th>Original URL</th>
          <th>Short URL</th>
          <th>Created</th>
          <th class="clicks">Clicks</th>
        </tr>
      </thead>
      <tbody>
        <% @links.each do |link| %>
          <tr>
            <td class="original-url" title="<%= link.original_url %>"><%= link.original_url %></td>
            <td><a href="<%= short_url_for(link) %>"><%= short_url_for(link) %></a></td>
            <td><%= link.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="clicks"><%= link.clicks %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty">No links yet.</p>
  <% end %>
</div>
